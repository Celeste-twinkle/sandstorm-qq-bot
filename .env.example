# OneBot reverse WebSocket server.
# Configure NapCat to connect to:
# ws://127.0.0.1:6700/onebot/v11/ws
PORT=6700
WS_PATH=/onebot/v11/ws

# Optional shared token. If set, NapCat must use the same token.
ACCESS_TOKEN=

# Insurgency: Sandstorm server query target.
# Query port is usually UDP 27015, but it can be different from the game port.
SANDSTORM_HOST=127.0.0.1
SANDSTORM_PORT=27015
QUERY_TIMEOUT_MS=7000

# Keyword matching.
# REQUIRE_AT=true means the bot replies only when the message mentions the bot and contains a keyword.
TRIGGER_KEYWORDS=叛乱,沙漠风暴,服务器状态,ins
REQUIRE_AT=true
COOLDOWN_SECONDS=20

# Optional: only reply in these QQ groups. Empty means all groups.
# Example: ALLOWED_GROUP_IDS=123456789,987654321
ALLOWED_GROUP_IDS=

# Message style.
BOT_NAME=沙暴状态

# DeepSeek chat.
# The bot answers normal chat messages when it is mentioned, while server-status keywords still query Sandstorm first.
CHAT_ENABLED=true
CHAT_REQUIRE_AT=true
CHAT_COOLDOWN_SECONDS=3

# Ambient group chat. Messages that do not mention the bot may randomly get a short
# casual reply, or get a guaranteed reply after the group stays quiet for a while.
# This is intentionally separate from @bot Q&A, but uses a short group context window.
AMBIENT_CHAT_ENABLED=true
# Immediate random reply chance. 0.2 means about 20% of normal non-@ text messages.
AMBIENT_CHAT_PROBABILITY=0.2
# Group-level cooldown for immediate random replies, to avoid flooding.
AMBIENT_CHAT_COOLDOWN_SECONDS=30
# If nobody sends another non-image message for this many seconds, reply once with 100% chance.
AMBIENT_CHAT_IDLE_SECONDS=60
# Maximum recent non-image messages used for immediate random replies.
AMBIENT_CHAT_INSTANT_MAX_MESSAGES=4
# Maximum recent non-image messages collected for the idle reply.
AMBIENT_CHAT_IDLE_MAX_MESSAGES=6
# Context time window for idle replies. The bot samples recent group text messages from newest to oldest.
AMBIENT_CHAT_CONTEXT_SECONDS=300
AMBIENT_CHAT_TIMEOUT_MS=12000
AMBIENT_CHAT_MAX_OUTPUT_TOKENS=180
AMBIENT_CHAT_SYSTEM_PROMPT=你是一只接入 QQ 群聊的中文猫娘机器人。现在你是在群聊里偶尔插一句闲聊，不是回答问题。请用中文快速回复 1 句，优先 20-45 个字，必要时最多 70 个字；必须自然带一次“喵”；语气像二次元社区玩家路过接梗、轻吐槽或轻轻感叹，可以有一点游戏群/番剧群的弹幕感，但味不要太冲；吐槽要友善，不恶意、不阴阳怪气、不嘲讽、不攻击任何人；不要说教，不要长篇解释，不要提到自己是 AI。
RESPONSE_NEUTRALITY_PROMPT=回复必须避免表现出政治或宗教倾向。不要主动引入政治、宗教、意识形态立场；如果用户内容涉及这些话题，只做中立、克制、事实性或轻轻转移话题的回应，不站队、不宣传、不劝诱、不评价任何政治或宗教群体。

CHAT_MAX_HISTORY_MESSAGES=16
CHAT_MAX_CONTEXT_CHARS=12000
CHAT_SESSION_TTL_MINUTES=120

# Put your real key in .env. Do not commit the real key to .env.example.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_MAX_OUTPUT_TOKENS=1600
# Thinking uses completion tokens for hidden reasoning too, so it needs a larger budget and timeout.
DEEPSEEK_THINKING_TIMEOUT_MS=60000
DEEPSEEK_THINKING_MAX_OUTPUT_TOKENS=3200
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_REASONING_EFFORT=high

# Local web search tool mode. When a message contains one of WEB_SEARCH_TRIGGER_KEYWORDS,
# the bot uses DeepSeek official tools/function calling, runs web_search/web_fetch
# locally, then answers with sources. Add "深度思考" in the same message to also
# enable thinking for the search workflow.
WEB_SEARCH_TRIGGER_KEYWORDS=联网搜索,联网查询,联网搜搜
WEB_SEARCH_PROVIDER=open-websearch
WEB_SEARCH_MAX_RESULTS=3
# Local candidate pool before filtering. Larger values improve freshness ranking without exposing more text to AI.
WEB_SEARCH_CANDIDATE_RESULTS=8
WEB_SEARCH_MAX_TOOL_ROUNDS=2
WEB_SEARCH_MAX_TOOL_CALLS_PER_ROUND=2
WEB_SEARCH_TIMEOUT_MS=10000
WEB_FETCH_MAX_CHARS=1000
WEB_SEARCH_SNIPPET_MAX_CHARS=220
# Higher values filter unrelated search results more aggressively. 0 disables score filtering.
WEB_SEARCH_MIN_RELEVANCE_SCORE=3
OPEN_WEBSEARCH_ENGINES=duckduckgo,startpage,sogou
OPEN_WEBSEARCH_MODE=auto
# Common proxy/TUN fake-IP range. Empty it only if your DNS returns real public IPs.
OPEN_WEBSEARCH_FAKE_IP_CIDRS=198.18.0.0/15

# Bilibili video resolver. Group Bilibili/b23 video links are handled without @bot;
# normal web URLs are ignored.
# Providers are tried in order. injahow and mir6 are external services and may become unavailable.
BILIBILI_ENABLED=true
BILIBILI_PROVIDERS=mir6,injahow
BILIBILI_SEND_VIDEO=true
# Extra Bilibili official metadata request. Disabled by default to avoid extra load.
BILIBILI_METADATA_ENABLED=false
BILIBILI_TIMEOUT_MS=15000

# Optional hosted providers. Leave empty to use embedded open-websearch without API keys.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_COUNTRY=US
BRAVE_SEARCH_LANG=zh-hans
BRAVE_SEARCH_UI_LANG=zh-CN

# Bing HTML fallback locale.
WEB_SEARCH_LANGUAGE=zh-CN,zh;q=0.9,en;q=0.8
WEB_SEARCH_LANGUAGE_CODE=zh-CN
WEB_SEARCH_COUNTRY_CODE=CN
WEB_SEARCH_MARKET=zh-CN

DEEPSEEK_SYSTEM_PROMPT=你是一只接入 QQ 群聊的中文猫娘机器人。回答要自然、简洁、有帮助，语气可爱但不过度；每次回复至少自然地带一次 喵~；不知道时直接说明，不编造。
